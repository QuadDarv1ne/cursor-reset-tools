# ============================================
# Cursor Reset Tools - Environment Configuration
# ============================================
# Скопируйте этот файл в .env и настройте значения
# ============================================

# ============================================
# Сервер
# ============================================
PORT=3000
WS_PORT=3001
HOST=localhost
NODE_ENV=development

# ============================================
# Логирование
# ============================================
LOG_LEVEL=info
# Доступные уровни: error, warn, info, debug, verbose
LOG_FILE=logs/app.log
LOG_MAX_FILES=30
LOG_MAX_SIZE=10m

# ============================================
# Автообновление
# ============================================
AUTO_UPDATE_ENABLED=true
UPDATE_CHECK_INTERVAL=86400000

# ============================================
# Уведомления (опционально)
# ============================================
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
DISCORD_WEBHOOK_URL=

# ============================================
# Прокси (опционально)
# ============================================
PROXY_ENABLED=false
PROXY_URL=
PROXY_PROTOCOL=socks5

# ============================================
# VPN (опционально)
# ============================================
VPN_ENABLED=false
VPN_TYPE=wireguard
VPN_CONFIG_PATH=

# ============================================
# DNS (опционально)
# ============================================
DNS_PROVIDER=cloudflare
# Доступные: cloudflare, google, quad9, opendns

# ============================================
# Метрики и мониторинг
# ============================================
METRICS_ENABLED=false
METRICS_INTERVAL=60000

# ============================================
# Безопасность
# ============================================
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
CSP_ENABLED=false

# ============================================
# Кэширование
# ============================================
CACHE_TTL_DEFAULT=5000
CACHE_MAX_SIZE=1000

# ============================================
# База данных (SQLite)
# ============================================
DB_PATH=data/app.db

# ============================================
# Резервное копирование
# ============================================
BACKUP_ENABLED=true
BACKUP_PATH=backups
BACKUP_MAX_COUNT=10
BACKUP_AUTO_INTERVAL=86400000
