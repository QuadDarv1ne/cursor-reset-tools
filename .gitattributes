# Auto detect text files and perform LF normalization
* text=auto

# Explicitly declare source code files as LF
*.js text eol=lf
*.ts text eol=lf
*.json text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.md text eol=lf
*.html text eol=lf
*.css text eol=lf
*.scss text eol=lf

# Windows batch files should use CRLF
*.bat text eol=crlf
*.cmd text eol=crlf

# Shell scripts should use LF
*.sh text eol=lf
Makefile text eol=lf

# Binary files - no EOL normalization
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.svg binary
*.woff binary
*.woff2 binary
*.ttf binary
*.eot binary

# SQLite databases
*.db binary
*.sqlite binary

# Lock files
package-lock.json text eol=lf
yarn.lock text eol=lf
