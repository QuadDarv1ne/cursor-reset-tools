{
  "transform": {},
  "testEnvironment": "node",
  "moduleNameMapper": {
    "^(\\.{1,2}/.*)\\.js$": "$1"
  },
  "testMatch": [
    "**/test/**/*.test.js"
  ],
  "testPathIgnorePatterns": [
    "/node_modules/",
    "/e2e/"
  ],
  "verbose": true,
  "testTimeout": 30000,
  "collectCoverageFrom": [
    "utils/**/*.js",
    "routes/**/*.js",
    "!**/node_modules/**"
  ],
  "coverageDirectory": "coverage",
  "coverageReporters": ["text", "lcov", "html"],
  "coverageThreshold": {
    "global": {
      "branches": 70,
      "functions": 70,
      "lines": 70,
      "statements": 70
    }
  }
}
