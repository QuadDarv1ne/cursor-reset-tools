{
  "name": "cursor-reset-tools",
  "version": "2.8.0-dev",
  "description": "this is a tool to reset the machine id of cursor",
  "main": "app.js",
  "type": "module",
  "bin": {
    "cursor-reset": "./cli.js"
  },
  "author": {
    "name": "Dupley Maxim Igorevich",
    "url": "https://github.com/QuadDarv1ne"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/QuadDarv1ne/cursor-reset-tools.git"
  },
  "bugs": {
    "url": "https://github.com/QuadDarv1ne/cursor-reset-tools/issues"
  },
  "homepage": "https://github.com/QuadDarv1ne/cursor-reset-tools#readme",
  "keywords": [
    "cursor",
    "cursor-ide",
    "machine-id",
    "reset-tool",
    "bypass",
    "token-limit",
    "pro-trial",
    "vpn-bypass",
    "dns-changer",
    "proxy-rotation",
    "nodejs",
    "express",
    "cli-tool",
    "developer-tools"
  ],
  "scripts": {
    "start": "node app.js",
    "dev": "nodemon app.js",
    "cli": "node cli.js",
    "server": "node server/bypassServer.js",
    "update": "node cli.js updater:check",
    "quick": "node scripts/quick-setup.js",
    "test": "node --experimental-vm-modules node_modules/jest/bin/jest.js",
    "test:coverage": "node --experimental-vm-modules node_modules/jest/bin/jest.js --coverage --coverageDirectory=coverage",
    "test:verbose": "node --experimental-vm-modules node_modules/jest/bin/jest.js --verbose",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:report": "playwright show-report",
    "coverage:report": "nyc report --reporter=html --reporter=text",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "check:i18n": "node scripts/check-i18n.js",
    "check:i18n:verbose": "node scripts/check-i18n.js --verbose",
    "docker:build": "docker build -t cursor-reset-tools .",
    "docker:run": "docker run -p 3000:3000 -v $(pwd)/data:/app/data cursor-reset-tools",
    "docker:dev": "docker-compose up --build",
    "prepare": "husky"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^17.3.1",
    "ejs": "^3.1.9",
    "express": "^4.18.2",
    "express-rate-limit": "^7.5.1",
    "fs-extra": "^11.1.1",
    "helmet": "^7.2.0",
    "hpagent": "^1.2.0",
    "http-proxy-agent": "^8.0.0",
    "http-proxy-middleware": "^3.0.5",
    "node-fetch": "^3.3.2",
    "socks-proxy-agent": "^9.0.0",
    "sqlite": "^5.1.1",
    "sqlite3": "^6.0.1",
    "uuid": "^9.0.0",
    "winston": "^3.19.0",
    "winston-daily-rotate-file": "^5.0.0",
    "ws": "^8.20.0"
  },
  "devDependencies": {
    "@jest/globals": "^30.3.0",
    "@playwright/test": "^1.58.2",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "husky": "^9.1.7",
    "jest": "^30.3.0",
    "lint-staged": "^16.1.2",
    "nodemon": "^3.1.14",
    "nyc": "^18.0.0",
    "prettier": "^3.8.1"
  },
  "lint-staged": {
    "*.js": [
      "eslint --fix"
    ],
    "*.{json,md}": [
      "prettier --write"
    ]
  }
}
