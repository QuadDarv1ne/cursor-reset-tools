<!DOCTYPE html>
<html lang="ru">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Bypass Tools - Cursor Reset Tools</title>
  <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Google+Sans:wght@400;500;700&display=swap">
  <link href="https://cdn.jsdelivr.net/npm/remixicon@3.5.0/fonts/remixicon.css" rel="stylesheet">
  <script src="https://cdn.tailwindcss.com"></script>
  <style>
    body {
      font-family: 'Google Sans', sans-serif;
      background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
      min-height: 100vh;
      padding: 20px;
    }
    .container { max-width: 1200px; margin: 0 auto; }
    .card {
      background: white;
      border-radius: 12px;
      box-shadow: 0 4px 20px rgba(0,0,0,0.15);
      margin-bottom: 20px;
      overflow: hidden;
    }
    .card-header {
      background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
      color: white;
      padding: 16px 20px;
      display: flex;
      align-items: center;
      gap: 10px;
    }
    .card-header h2 { font-size: 18px; font-weight: 500; margin: 0; }
    .card-body { padding: 20px; }
    .btn {
      padding: 10px 20px;
      border: none;
      border-radius: 8px;
      cursor: pointer;
      font-size: 14px;
      font-weight: 500;
      display: inline-flex;
      align-items: center;
      gap: 8px;
      transition: all 0.2s;
    }
    .btn-primary { background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); color: white; }
    .btn-primary:hover { transform: translateY(-2px); box-shadow: 0 4px 12px rgba(102,126,234,0.4); }
    .btn-success { background: #10b981; color: white; }
    .btn-danger { background: #ef4444; color: white; }
    .btn-warning { background: #f59e0b; color: white; }
    .btn-secondary { background: #6b7280; color: white; }
    .btn:disabled { opacity: 0.5; cursor: not-allowed; }
    .status-badge {
      padding: 4px 12px;
      border-radius: 20px;
      font-size: 12px;
      font-weight: 500;
    }
    .status-success { background: #d1fae5; color: #065f46; }
    .status-error { background: #fee2e2; color: #991b1b; }
    .status-warning { background: #fef3c7; color: #92400e; }
    .input-group { margin-bottom: 16px; }
    .input-group label { display: block; margin-bottom: 6px; font-weight: 500; color: #374151; }
    .input-group input, .input-group select {
      width: 100%;
      padding: 10px 14px;
      border: 1px solid #d1d5db;
      border-radius: 8px;
      font-size: 14px;
      box-sizing: border-box;
    }
    .input-group input:focus { outline: none; border-color: #667eea; box-shadow: 0 0 0 3px rgba(102,126,234,0.1); }
    .log-output {
      background: #1f2937;
      color: #10b981;
      padding: 16px;
      border-radius: 8px;
      font-family: 'Courier New', monospace;
      font-size: 13px;
      max-height: 300px;
      overflow-y: auto;
    }
    .grid-2 { display: grid; grid-template-columns: repeat(auto-fit, minmax(300px, 1fr)); gap: 20px; }
    .grid-3 { display: grid; grid-template-columns: repeat(auto-fit, minmax(250px, 1fr)); gap: 20px; }
    .stat-card {
      background: #f9fafb;
      padding: 16px;
      border-radius: 8px;
      text-align: center;
    }
    .stat-value { font-size: 24px; font-weight: 700; color: #667eea; }
    .stat-label { font-size: 13px; color: #6b7280; margin-top: 4px; }
    .proxy-item {
      display: flex;
      justify-content: space-between;
      align-items: center;
      padding: 12px;
      border: 1px solid #e5e7eb;
      border-radius: 8px;
      margin-bottom: 8px;
    }
    .proxy-item.current { border-color: #10b981; background: #d1fae5; }
    .loading { opacity: 0.6; pointer-events: none; }
    .spinner { animation: spin 1s linear infinite; }
    @keyframes spin { 100% { transform: rotate(360deg); } }
  </style>
</head>
<body>
  <div class="container">
    <header style="text-align: center; color: white; margin-bottom: 30px;">
      <h1 style="font-size: 32px; margin-bottom: 8px;">🛡️ Bypass Tools</h1>
      <p style="opacity: 0.9;">Инструменты для обхода региональных ограничений Cursor</p>
      <a href="/" style="color: white; text-decoration: underline; font-size: 14px;">← На главную</a>
    </header>

    <!-- Monitor Status -->
    <div class="card">
      <div class="card-header">
        <h2><i class="ri-radar-line"></i> Статус Cursor API</h2>
        <button class="btn btn-secondary btn-sm" onclick="checkMonitor()" style="margin-left: auto;">
          <i class="ri-refresh-line"></i> Обновить
        </button>
      </div>
      <div class="card-body">
        <div id="monitor-status" class="grid-3">
          <div class="stat-card">
            <div class="stat-value" id="cursor-status">--</div>
            <div class="stat-label">Cursor API</div>
          </div>
          <div class="stat-card">
            <div class="stat-value" id="ip-address">--</div>
            <div class="stat-label">Ваш IP</div>
          </div>
          <div class="stat-card">
            <div class="stat-value" id="ip-country">--</div>
            <div class="stat-label">Страна</div>
          </div>
        </div>
        <div id="monitor-recommendations" style="margin-top: 16px;"></div>
      </div>
    </div>

    <!-- System Info -->
    <div class="card">
      <div class="card-header">
        <h2><i class="ri-computer-line"></i> Информация о системе</h2>
      </div>
      <div class="card-body">
        <div id="system-info" class="grid-3">
          <div class="stat-card">
            <div class="stat-value">Загрузка...</div>
            <div class="stat-label">Платформа</div>
          </div>
          <div class="stat-card">
            <div class="stat-value">Загрузка...</div>
            <div class="stat-label">Архитектура</div>
          </div>
          <div class="stat-card">
            <div class="stat-value">Загрузка...</div>
            <div class="stat-label">Cursor</div>
          </div>
        </div>
      </div>
    </div>

    <!-- Proxy Manager -->
    <div class="card">
      <div class="card-header">
        <h2><i class="ri-global-line"></i> Proxy Manager</h2>
      </div>
      <div class="card-body">
        <div class="input-group">
          <label>Добавить прокси</label>
          <div style="display: flex; gap: 8px; flex-wrap: wrap;">
            <input type="text" id="proxy-url" placeholder="host:port или user:pass@host:port" style="flex: 1; min-width: 200px;">
            <select id="proxy-protocol" style="width: 120px;">
              <option value="socks5">SOCKS5</option>
              <option value="http">HTTP</option>
            </select>
            <button class="btn btn-primary" onclick="addProxy()">
              <i class="ri-add-line"></i> Добавить
            </button>
          </div>
        </div>
        <div style="display: flex; gap: 8px; margin-bottom: 16px; flex-wrap: wrap;">
          <button class="btn btn-success" onclick="checkProxies()">
            <i class="ri-checkbox-circle-line"></i> Проверить
          </button>
          <button class="btn btn-warning" onclick="rotateProxy()">
            <i class="ri-shuffle-line"></i> Ротация
          </button>
          <button class="btn btn-danger" onclick="clearProxy()">
            <i class="ri-delete-bin-line"></i> Очистить
          </button>
        </div>
        <div id="proxy-list"></div>
      </div>
    </div>

    <!-- DNS Manager -->
    <div class="card">
      <div class="card-header">
        <h2><i class="ri-server-line"></i> DNS Manager</h2>
      </div>
      <div class="card-body">
        <div class="input-group">
          <label>Текущий DNS</label>
          <div id="current-dns" class="stat-card" style="text-align: left; margin-bottom: 16px;">
            <div class="stat-value" id="dns-primary">--</div>
            <div class="stat-label" id="dns-secondary">--</div>
          </div>
        </div>
        <div class="input-group">
          <label>Выбрать DNS провайдер</label>
          <select id="dns-provider" style="max-width: 300px;">
            <option value="cloudflare">Cloudflare (1.1.1.1)</option>
            <option value="google">Google (8.8.8.8)</option>
            <option value="quad9">Quad9 (9.9.9.9)</option>
            <option value="opendns">OpenDNS</option>
            <option value="adguard">AdGuard DNS</option>
            <option value="auto">Автоматически (DHCP)</option>
          </select>
        </div>
        <div style="display: flex; gap: 8px; margin-top: 16px; flex-wrap: wrap;">
          <button class="btn btn-primary" onclick="setDNS()">
            <i class="ri-check-line"></i> Установить
          </button>
          <button class="btn btn-secondary" onclick="restoreDNS()">
            <i class="ri-reply-line"></i> Восстановить
          </button>
          <button class="btn btn-secondary" onclick="flushDNS()">
            <i class="ri-broom-line"></i> Очистить кэш
          </button>
        </div>
      </div>
    </div>

    <!-- Fingerprint -->
    <div class="card">
      <div class="card-header">
        <h2><i class="ri-fingerprint-line"></i> Fingerprint</h2>
      </div>
      <div class="card-body">
        <div id="fingerprint-info" class="stat-card" style="text-align: left; margin-bottom: 16px;">
          <div><strong>Hostname:</strong> <span id="fp-hostname">--</span></div>
          <div><strong>MAC адресов:</strong> <span id="fp-mac-count">--</span></div>
          <div><strong>Платформа:</strong> <span id="fp-platform">--</span></div>
        </div>
        <div style="display: flex; gap: 8px; flex-wrap: wrap;">
          <button class="btn btn-primary" onclick="resetFingerprint()">
            <i class="ri-restart-line"></i> Полный сброс
          </button>
          <button class="btn btn-warning" onclick="changeMAC()">
            <i class="ri-network-line"></i> Сменить MAC
          </button>
          <button class="btn btn-warning" onclick="changeHostname()">
            <i class="ri-edit-line"></i> Сменить hostname
          </button>
        </div>
      </div>
    </div>

    <!-- VPN Status -->
    <div class="card">
      <div class="card-header">
        <h2><i class="ri-shield-keyhole-line"></i> VPN Статус</h2>
        <button class="btn btn-secondary btn-sm" onclick="checkVPN()" style="margin-left: auto;">
          <i class="ri-refresh-line"></i> Обновить
        </button>
      </div>
      <div class="card-body">
        <div id="vpn-status" class="grid-3">
          <div class="stat-card">
            <div class="stat-value" id="vpn-active">--</div>
            <div class="stat-label">Статус VPN</div>
          </div>
          <div class="stat-card">
            <div class="stat-value" id="vpn-country">--</div>
            <div class="stat-label">Страна</div>
          </div>
          <div class="stat-card">
            <div class="stat-value" id="vpn-ip">--</div>
            <div class="stat-label">Ваш IP</div>
          </div>
        </div>
        <div id="vpn-info" style="margin-top: 16px;"></div>
      </div>
    </div>

    <!-- Notifications -->
    <div class="card">
      <div class="card-body">
        <div class="grid-2">
          <div class="stat-card">
            <h3>Telegram</h3>
            <div id="telegram-status" class="status-badge status-error">✗ Не настроен</div>
          </div>
          <div class="stat-card">
            <h3>Discord</h3>
            <div id="discord-status" class="status-badge status-error">✗ Не настроен</div>
          </div>
        </div>
        <div class="input-group" style="margin-top: 16px;">
          <label>Telegram Bot Token</label>
          <input type="text" id="telegram-token" placeholder="123456:ABC-DEF1234ghIkl-zyx57W2v1u123ew11">
        </div>
        <div class="input-group">
          <label>Telegram Chat ID</label>
          <input type="text" id="telegram-chat-id" placeholder="123456789">
        </div>
        <div class="input-group">
          <label>Discord Webhook URL</label>
          <input type="text" id="discord-webhook" placeholder="https://discord.com/api/webhooks/...">
        </div>
        <div style="display: flex; gap: 8px; flex-wrap: wrap; margin-top: 16px;">
          <button class="btn btn-primary" onclick="saveTelegramConfig()">
            <i class="ri-save-line"></i> Сохранить Telegram
          </button>
          <button class="btn btn-primary" onclick="saveDiscordConfig()">
            <i class="ri-save-line"></i> Сохранить Discord
          </button>
          <button class="btn btn-success" onclick="testNotification()">
            <i class="ri-send-plane-line"></i> Тест
          </button>
        </div>
      </div>
    </div>

    <!-- Proxy Auto-Rotation -->
    <div class="card">
      <div class="card-header">
        <h2><i class="ri-repeat-2-line"></i> Авто-ротация прокси</h2>
      </div>
      <div class="card-body">
        <div class="stat-card" style="margin-bottom: 16px;">
          <div><strong>Статус:</strong> <span id="auto-rotation-status" class="status-badge status-error">✗ Выключена</span></div>
          <div><strong>Интервал:</strong> <span id="rotation-interval">--</span></div>
          <div><strong>Ротаций:</strong> <span id="rotation-count">0</span></div>
        </div>
        <div class="input-group">
          <label>Интервал ротации (мс)</label>
          <input type="number" id="rotation-interval-input" value="300000" step="60000" min="60000">
        </div>
        <div style="display: flex; gap: 8px; flex-wrap: wrap; margin-top: 16px;">
          <button class="btn btn-success" onclick="startAutoRotation()">
            <i class="ri-play-line"></i> Включить
          </button>
          <button class="btn btn-danger" onclick="stopAutoRotation()">
            <i class="ri-stop-line"></i> Выключить
          </button>
          <button class="btn btn-primary" onclick="forceRotateProxy()">
            <i class="ri-arrow-right-circle-line"></i> Ротировать сейчас
          </button>
        </div>
      </div>
    </div>

      <!-- Email -->
      <div class="card">
        <div class="card-header">
          <h2><i class="ri-mail-line"></i> Временный Email</h2>
        </div>
        <div class="card-body">
          <div id="email-session" class="stat-card" style="text-align: left; margin-bottom: 16px;">
            <div><strong>Email:</strong> <span id="email-address">Не создан</span></div>
            <div><strong>Сервис:</strong> <span id="email-service">--</span></div>
          </div>
          <div class="input-group">
            <label>Сервис</label>
            <select id="email-service-select">
              <option value="guerrillamail">Guerrilla Mail</option>
              <option value="tempmail">Temp Mail</option>
              <option value="mailinator">Mailinator</option>
            </select>
          </div>
          <div style="display: flex; gap: 8px; flex-wrap: wrap;">
            <button class="btn btn-primary" onclick="createEmail()">
              <i class="ri-add-circle-line"></i> Создать
            </button>
            <button class="btn btn-success" onclick="checkEmail()">
              <i class="ri-inbox-line"></i> Проверить
            </button>
            <button class="btn btn-warning" onclick="waitForCursorEmail()">
              <i class="ri-time-line"></i> Ждать Cursor
            </button>
          </div>
          <div id="email-messages" style="margin-top: 16px; max-height: 200px; overflow-y: auto;"></div>
        </div>
      </div>
    </div>

    <!-- Smart Bypass -->
    <div class="card">
      <div class="card-header">
        <h2><i class="ri-brain-line"></i> Smart Bypass</h2>
        <span id="smart-status" class="status-badge status-success" style="margin-left: auto;">
          <i class="ri-wifi-line"></i> WebSocket подключен
        </span>
      </div>
      <div class="card-body">
        <div class="grid-3" id="smart-methods">
          <div class="stat-card">
            <div class="stat-value" id="method-direct">--</div>
            <div class="stat-label">Прямое подключение</div>
          </div>
          <div class="stat-card">
            <div class="stat-value" id="method-doh">--</div>
            <div class="stat-label">DNS over HTTPS</div>
          </div>
          <div class="stat-card">
            <div class="stat-value" id="method-proxy">--</div>
            <div class="stat-label">Прокси</div>
          </div>
        </div>
        <div style="margin-top: 16px; padding: 12px; background: #f9fafb; border-radius: 8px;">
          <div style="display: flex; justify-content: space-between; align-items: center;">
            <div>
              <strong>Лучший метод:</strong> <span id="best-method" style="color: #667eea;">--</span>
            </div>
            <div style="display: flex; gap: 8px;">
              <button class="btn btn-secondary btn-sm" onclick="testBypass()">
                <i class="ri-test-tube-line"></i> Тест
              </button>
              <button class="btn btn-primary btn-sm" onclick="applyBestBypass()">
                <i class="ri-play-circle-line"></i> Применить
              </button>
            </div>
          </div>
        </div>
        <div id="smart-recommendations" style="margin-top: 16px;"></div>
      </div>
    </div>

    <!-- Auto Bypass -->
    <div class="card">
      <div class="card-header">
        <h2><i class="ri-rocket-line"></i> Авто-обход</h2>
      </div>
      <div class="card-body">
        <p style="margin-bottom: 16px; color: #6b7280;">
          Автоматическая смена IP, DNS и fingerprint для обхода блокировок Cursor
        </p>
        <div style="display: flex; gap: 16px; margin-bottom: 16px; flex-wrap: wrap;">
          <label><input type="checkbox" id="bypass-proxy" checked> Сменить прокси</label>
          <label><input type="checkbox" id="bypass-dns" checked> Сменить DNS</label>
          <label><input type="checkbox" id="bypass-fingerprint"> Сменить fingerprint</label>
        </div>
        <button class="btn btn-primary" onclick="autoBypass()" id="btn-auto-bypass">
          <i class="ri-play-circle-line"></i> Запустить авто-обход
        </button>
        <div id="bypass-result" style="margin-top: 16px;"></div>
      </div>
    </div>

    <!-- Log Output -->
    <div class="card">
      <div class="card-header">
        <h2><i class="ri-terminal-box-line"></i> Лог операций</h2>
        <button class="btn btn-secondary btn-sm" onclick="clearLog()" style="margin-left: auto;">
          <i class="ri-delete-bin-line"></i> Очистить
        </button>
      </div>
      <div class="card-body">
        <div id="log-output" class="log-output"></div>
      </div>
    </div>
  </div>

  <script>
    const API_BASE = '/api';
    const wsPort = <%= typeof wsPort !== 'undefined' ? wsPort : 3001 %>;
    let logBuffer = [];

    function log(message, type = 'info') {
      const timestamp = new Date().toLocaleTimeString();
      const icon = type === 'error' ? '❌' : type === 'success' ? '✅' : 'ℹ️';
      logBuffer.push(`[${timestamp}] ${icon} ${message}`);
      renderLog();
    }

    function renderLog() {
      const output = document.getElementById('log-output');
      output.innerHTML = logBuffer.join('\n');
      output.scrollTop = output.scrollHeight;
    }

    function clearLog() {
      logBuffer = [];
      renderLog();
    }

    async function api(endpoint, options = {}) {
      try {
        const response = await fetch(`${API_BASE}${endpoint}`, {
          ...options,
          headers: { 'Content-Type': 'application/json', ...options.headers }
        });
        return await response.json();
      } catch (error) {
        log(`API error: ${error.message}`, 'error');
        return { error: error.message };
      }
    }

    // Monitor
    async function checkMonitor() {
      log('Проверка статуса Cursor...');
      const result = await api('/monitor/check');

      if (result.success) {
        document.getElementById('cursor-status').innerHTML =
          result.cursorAvailable
            ? '<span class="status-badge status-success">Доступен</span>'
            : '<span class="status-badge status-error">Заблокирован</span>';

        document.getElementById('ip-address').textContent = result.ip?.ip || '--';
        document.getElementById('ip-country').textContent =
          `${result.ip?.country || '--'} (${result.ip?.countryCode || '--'})`;

        const recContainer = document.getElementById('monitor-recommendations');
        if (result.recommendations?.length > 0) {
          recContainer.innerHTML = result.recommendations.map(r =>
            `<div class="status-badge status-warning" style="display: inline-block; margin: 4px;">⚠️ ${r.message}</div>`
          ).join('');
        } else {
          recContainer.innerHTML = '<span class="status-badge status-success">✓ Нет рекомендаций</span>';
        }

        log(`Cursor: ${result.cursorAvailable ? 'доступен' : 'заблокирован'}`,
            result.cursorAvailable ? 'success' : 'error');
      }
    }

    // Загрузка информации о системе и Cursor
    async function loadSystemInfo() {
      try {
        const response = await fetch('/api/paths');
        const p = await response.json();

        // Обновление информации о системе (если есть элементы)
        const systemEl = document.getElementById('system-info');
        if (systemEl) {
          systemEl.innerHTML = `
            <div class="stat-card">
              <div class="stat-value">${p.platform || 'Windows'}</div>
              <div class="stat-label">Платформа</div>
            </div>
            <div class="stat-card">
              <div class="stat-value">${p.arch || 'x64'}</div>
              <div class="stat-label">Архитектура</div>
            </div>
            <div class="stat-card">
              <div class="stat-value">${p.isRunning ? 'Запущен' : 'Остановлен'}</div>
              <div class="stat-label">Cursor</div>
            </div>
          `;
        }
      } catch (error) {
        console.error('Ошибка загрузки информации о системе:', error);
      }
    }

    // Proxy
    async function addProxy() {
      const url = document.getElementById('proxy-url').value;
      const protocol = document.getElementById('proxy-protocol').value;
      
      if (!url) { log('Введите URL прокси', 'error'); return; }
      
      log(`Добавление прокси: ${url} (${protocol})`);
      const result = await api('/proxy/add', {
        method: 'POST',
        body: JSON.stringify({ url, protocol })
      });
      
      if (result.success) {
        log('Прокси добавлен', 'success');
        document.getElementById('proxy-url').value = '';
        loadProxyList();
      } else {
        log(`Ошибка: ${result.error}`, 'error');
      }
    }

    async function loadProxyList() {
      const result = await api('/proxy/list');
      if (result.success) {
        const container = document.getElementById('proxy-list');
        if (result.proxies.length === 0) {
          container.innerHTML = '<p style="color: #6b7280;">Список прокси пуст</p>';
        } else {
          container.innerHTML = result.proxies.map((p, i) => `
            <div class="proxy-item ${p.url === result.stats.currentProxy ? 'current' : ''}">
              <div>
                <strong>${p.url}</strong>
                <span class="status-badge ${p.working ? 'status-success' : 'status-error'}">
                  ${p.working ? '✓' : '✗'}
                </span>
              </div>
              ${p.url === result.stats.currentProxy ? '<span class="status-badge status-success">Текущий</span>' : ''}
            </div>
          `).join('');
        }
      }
    }

    async function checkProxies() {
      log('Проверка всех прокси...');
      const result = await api('/proxy/check', { method: 'POST' });
      if (result.success) {
        log(`Проверено: ${result.working.length} рабочих, ${result.failed.length} нерабочих`, 
            result.working.length > 0 ? 'success' : 'error');
        loadProxyList();
      }
    }

    async function rotateProxy() {
      log('Ротация прокси...');
      const result = await api('/proxy/rotate', { method: 'POST' });
      if (result.success) {
        log(`Прокси сменён: ${result.proxy.url}`, 'success');
        loadProxyList();
      } else {
        log(`Ошибка: ${result.error}`, 'error');
      }
    }

    async function clearProxy() {
      log('Очистка прокси...');
      await api('/proxy/clear', { method: 'DELETE' });
      log('Прокси очищен', 'success');
      loadProxyList();
    }

    // Notifications
    async function loadNotificationStatus() {
      const result = await api('/notifications/status');
      if (result.success) {
        const tgStatus = document.getElementById('telegram-status');
        const dcStatus = document.getElementById('discord-status');
        
        if (tgStatus) {
          tgStatus.textContent = result.telegram.configured ? '✓ Настроен' : '✗ Не настроен';
          tgStatus.className = `status-badge ${result.telegram.configured ? 'status-success' : 'status-error'}`;
        }
        
        if (dcStatus) {
          dcStatus.textContent = result.discord.configured ? '✓ Настроен' : '✗ Не настроен';
          dcStatus.className = `status-badge ${result.discord.configured ? 'status-success' : 'status-error'}`;
        }
      }
    }

    async function saveTelegramConfig() {
      const token = document.getElementById('telegram-token').value;
      const chatId = document.getElementById('telegram-chat-id').value;
      
      if (!token || !chatId) {
        log('Введите Token и Chat ID', 'error');
        return;
      }
      
      log('Сохранение Telegram конфигурации...');
      const result = await api('/notifications/configure/telegram', {
        method: 'POST',
        body: JSON.stringify({ botToken: token, chatId })
      });
      
      if (result.success) {
        log('Telegram настроен', 'success');
        loadNotificationStatus();
      } else {
        log(`Ошибка: ${result.error}`, 'error');
      }
    }

    async function saveDiscordConfig() {
      const webhookUrl = document.getElementById('discord-webhook').value;
      
      if (!webhookUrl) {
        log('Введите Webhook URL', 'error');
        return;
      }
      
      log('Сохранение Discord конфигурации...');
      const result = await api('/notifications/configure/discord', {
        method: 'POST',
        body: JSON.stringify({ webhookUrl })
      });
      
      if (result.success) {
        log('Discord настроен', 'success');
        loadNotificationStatus();
      } else {
        log(`Ошибка: ${result.error}`, 'error');
      }
    }

    async function testNotification() {
      log('Отправка тестового уведомления...');
      const result = await api('/notifications/test', { method: 'POST' });
      
      if (result.success) {
        log('Тестовое уведомление отправлено', 'success');
      } else {
        log(`Ошибка: ${result.error}`, 'error');
      }
    }

    // Auto Rotation
    async function loadAutoRotationStatus() {
      const result = await api('/proxy/rotation/status');
      if (result.success) {
        const statusEl = document.getElementById('auto-rotation-status');
        const intervalEl = document.getElementById('rotation-interval');
        const countEl = document.getElementById('rotation-count');
        
        if (statusEl) {
          statusEl.textContent = result.enabled ? '✓ Включена' : '✗ Выключена';
          statusEl.className = `status-badge ${result.enabled ? 'status-success' : 'status-error'}`;
        }
        
        if (intervalEl) {
          intervalEl.textContent = result.enabled ? `${result.intervalMs / 1000}с` : '--';
        }
        
        if (countEl) {
          countEl.textContent = result.rotationCount || 0;
        }
      }
    }

    async function startAutoRotation() {
      const interval = parseInt(document.getElementById('rotation-interval-input').value);
      
      log(`Включение авто-ротации (интервал: ${interval}мс)...`);
      const result = await api('/proxy/rotation/start', {
        method: 'POST',
        body: JSON.stringify({ intervalMs: interval })
      });
      
      if (result.success) {
        log('Авто-ротация включена', 'success');
        loadAutoRotationStatus();
      } else {
        log(`Ошибка: ${result.error}`, 'error');
      }
    }

    async function stopAutoRotation() {
      log('Выключение авто-ротации...');
      const result = await api('/proxy/rotation/stop', { method: 'POST' });
      
      if (result.success) {
        log('Авто-ротация выключена', 'success');
        loadAutoRotationStatus();
      } else {
        log(`Ошибка: ${result.error}`, 'error');
      }
    }

    async function forceRotateProxy() {
      log('Принудительная ротация прокси...');
      const result = await api('/proxy/rotate', { method: 'POST' });
      
      if (result.success) {
        log(`Прокси ротирован: ${result.proxy?.url || 'новый'}`, 'success');
        loadAutoRotationStatus();
        loadProxyList();
      } else {
        log(`Ошибка: ${result.error}`, 'error');
      }
    }

    // DNS
    async function loadDNS() {
      const result = await api('/dns/current');
      if (result.success) {
        document.getElementById('dns-primary').textContent = result.dns.primary || '--';
        document.getElementById('dns-secondary').textContent = `Вторичный: ${result.dns.secondary || '--'}`;
      }
    }

    async function setDNS() {
      const provider = document.getElementById('dns-provider').value;
      log(`Установка DNS: ${provider}`);
      const result = await api('/dns/set', {
        method: 'POST',
        body: JSON.stringify({ provider })
      });
      if (result.success) {
        log(`DNS установлен: ${result.provider.name}`, 'success');
        loadDNS();
      } else {
        log(`Ошибка: ${result.error}`, 'error');
      }
    }

    async function restoreDNS() {
      log('Восстановление DNS...');
      const result = await api('/dns/restore', { method: 'POST' });
      if (result.success) {
        log('DNS восстановлен', 'success');
        loadDNS();
      }
    }

    async function flushDNS() {
      log('Очистка DNS кэша...');
      const result = await api('/dns/flush', { method: 'POST' });
      if (result.success) {
        log('DNS кэш очищен', 'success');
      }
    }

    // Fingerprint
    async function loadFingerprint() {
      const result = await api('/fingerprint/info');
      if (result.success) {
        document.getElementById('fp-hostname').textContent = result.info.info?.hostname || '--';
        document.getElementById('fp-mac-count').textContent = result.info.info?.macAddresses?.length || '--';
        document.getElementById('fp-platform').textContent = result.info.info?.platform || '--';
      }
    }

    // VPN
    async function checkVPN() {
      try {
        const response = await fetch('/api/vpn/status');
        const result = await response.json();
        
        if (result.success) {
          const status = result.status;
          
          document.getElementById('vpn-active').textContent = status.detected ? '✓ Активен' : '✗ Не активен';
          document.getElementById('vpn-active').className = status.detected ? 'stat-value status-success' : 'stat-value status-error';
          
          document.getElementById('vpn-country').textContent = status.country || '--';
          document.getElementById('vpn-ip').textContent = status.ip || '--';
          
          const infoEl = document.getElementById('vpn-info');
          if (status.detected) {
            infoEl.innerHTML = `
              <div class="status-badge status-success" style="display: inline-block; margin: 4px;">
                ✓ VPN: ${status.name || status.type || 'Unknown'}
              </div>
              <div class="status-badge status-info" style="display: inline-block; margin: 4px;">
                ISP: ${status.isp || '--'}
              </div>
            `;
            log(`VPN обнаружен: ${status.country} (${status.ip})`, 'success');
          } else {
            infoEl.innerHTML = '<span class="status-badge status-error">✗ VPN не обнаружен</span>';
            log('VPN не обнаружен', 'warning');
          }
        }
      } catch (error) {
        log(`Ошибка проверки VPN: ${error.message}`, 'error');
      }
    }

    async function resetFingerprint() {
      log('Сброс fingerprint...');
      const result = await api('/fingerprint/reset', {
        method: 'POST',
        body: JSON.stringify({})
      });
      if (result.success) {
        log('Fingerprint сброшен', 'success');
        loadFingerprint();
      }
    }

    async function changeMAC() {
      log('Смена MAC адресов...');
      const result = await api('/fingerprint/mac', { method: 'POST' });
      if (result.success) {
        log(`Изменено: ${result.result.success}/${result.result.total}`, 'success');
      }
    }

    async function changeHostname() {
      const newName = prompt('Введите новый hostname:');
      if (!newName) return;
      
      log(`Смена hostname: ${newName}`);
      const result = await api('/fingerprint/hostname', {
        method: 'POST',
        body: JSON.stringify({ name: newName })
      });
      if (result.success) {
        log('Hostname изменён', 'success');
        loadFingerprint();
      }
    }

    // Email
    async function createEmail() {
      const service = document.getElementById('email-service-select').value;
      log(`Создание email (${service})...`);
      const result = await api('/email/create', {
        method: 'POST',
        body: JSON.stringify({ service })
      });
      if (result.success) {
        log(`Email: ${result.email}`, 'success');
        document.getElementById('email-address').textContent = result.email;
        document.getElementById('email-service').textContent = result.service;
      } else {
        log(`Ошибка: ${result.error}`, 'error');
      }
    }

    async function checkEmail() {
      log('Проверка почты...');
      const result = await api('/email/messages');
      if (result.success) {
        const container = document.getElementById('email-messages');
        if (result.messages.length === 0) {
          container.innerHTML = '<p style="color: #6b7280;">Сообщений нет</p>';
        } else {
          container.innerHTML = result.messages.map(m => `
            <div style="padding: 8px; border-bottom: 1px solid #e5e7eb;">
              <strong>${m.subject || 'Без темы'}</strong><br>
              <small>От: ${m.from}</small>
            </div>
          `).join('');
        }
        log(`Сообщений: ${result.messages.length}`, 'success');
      }
    }

    async function waitForCursorEmail() {
      log('Ожидание письма от Cursor...');
      const result = await api('/email/wait', {
        method: 'POST',
        body: JSON.stringify({ timeout: 120000 })
      });
      if (result.success) {
        log(`Письмо получено: ${result.message.subject}`, 'success');
        if (result.code) log(`Код: ${result.code}`, 'success');
      } else {
        log('Письмо не получено (timeout)', 'error');
      }
    }

    // Auto Bypass
    async function autoBypass() {
      const btn = document.getElementById('btn-auto-bypass');
      btn.disabled = true;
      btn.classList.add('loading');
      
      log('Запуск авто-обхода...');
      
      const result = await api('/bypass/auto', {
        method: 'POST',
        body: JSON.stringify({
          changeProxy: document.getElementById('bypass-proxy').checked,
          changeDNS: document.getElementById('bypass-dns').checked,
          changeFingerprint: document.getElementById('bypass-fingerprint').checked
        })
      });
      
      btn.disabled = false;
      btn.classList.remove('loading');
      
      if (result.success) {
        log('Авто-обход завершён', 'success');
        
        const container = document.getElementById('bypass-result');
        container.innerHTML = `
          <div class="grid-3">
            <div class="stat-card">
              <div class="stat-value">${result.ipChanged ? '✓' : '✗'}</div>
              <div class="stat-label">IP изменён</div>
            </div>
            <div class="stat-card">
              <div class="stat-value">${result.dns?.success ? '✓' : '✗'}</div>
              <div class="stat-label">DNS изменён</div>
            </div>
            <div class="stat-card">
              <div class="stat-value">${result.cursorAvailable ? '✓' : '✗'}</div>
              <div class="stat-label">Cursor доступен</div>
            </div>
          </div>
        `;
        
        loadProxyList();
        loadDNS();
        loadFingerprint();
        checkMonitor();
      } else {
        log(`Ошибка: ${result.error}`, 'error');
      }
    }

    // Smart Bypass
    let ws = null;

    function initWebSocket() {
      // WebSocket работает на том же порту что и HTTP с путем /ws
      const wsUrl = `ws://${window.location.hostname}:${window.location.port || (window.location.protocol === 'https:' ? '443' : '80')}/ws`;
      ws = new WebSocket(wsUrl);

      ws.onopen = () => {
        log('WebSocket подключен', 'success');
        updateWebSocketStatus(true);
        // Запрос статуса
        ws.send(JSON.stringify({ type: 'request_status' }));
      };

      ws.onclose = () => {
        log('WebSocket отключен, переподключение...', 'error');
        updateWebSocketStatus(false);
        setTimeout(initWebSocket, 3000);
      };

      ws.onerror = (error) => {
        log(`WebSocket ошибка: ${error.message}`, 'error');
      };

      ws.onmessage = (event) => {
        try {
          const data = JSON.parse(event.data);
          handleWebSocketMessage(data);
        } catch (error) {
          log(`Ошибка парсинга WebSocket: ${error.message}`, 'error');
        }
      };
    }

    function updateWebSocketStatus(connected) {
      const status = document.getElementById('smart-status');
      if (connected) {
        status.className = 'status-badge status-success';
        status.innerHTML = '<i class="ri-wifi-line"></i> WebSocket подключен';
      } else {
        status.className = 'status-badge status-error';
        status.innerHTML = '<i class="ri-wifi-off-line"></i> Отключен';
      }
    }

    function handleWebSocketMessage(data) {
      switch (data.type) {
        case 'welcome':
          log(`Подключен к серверу: ${data.clientId}`, 'success');
          break;
        case 'status':
        case 'heartbeat':
          updateSmartBypassUI(data.data);
          break;
        case 'bypass_test_result':
          displayBypassTestResult(data.result, data.best);
          break;
        case 'bypass_applied':
          log(`Smart Bypass применен: ${data.result.method}`, 'success');
          break;
        case 'server_restart':
          log(`Сервер перезапущен на порту ${data.newPort}`, 'warning');
          break;
      }
    }

    function updateSmartBypassUI(data) {
      if (!data || !data.bypass) return;

      const methods = data.bypass.methods || {};

      // Обновление весов методов
      const directEl = document.getElementById('method-direct');
      const dohEl = document.getElementById('method-doh');
      const proxyEl = document.getElementById('method-proxy');

      if (directEl) {
        directEl.textContent = methods.direct?.weight > 0 ? `✓ ${methods.direct.weight}%` : '✗';
        directEl.style.color = methods.direct?.weight > 0 ? '#10b981' : '#ef4444';
      }

      if (dohEl) {
        dohEl.textContent = methods.doh?.weight > 0 ? `✓ ${methods.doh.weight}%` : '✗';
        dohEl.style.color = methods.doh?.weight > 0 ? '#10b981' : '#ef4444';
      }

      if (proxyEl) {
        proxyEl.textContent = methods.proxy?.weight > 0 ? `✓ ${methods.proxy.weight}%` : '✗';
        proxyEl.style.color = methods.proxy?.weight > 0 ? '#10b981' : '#ef4444';
      }

      // Лучший метод
      const bestEl = document.getElementById('best-method');
      if (bestEl && data.bypass.bestMethod) {
        const methodNames = {
          direct: 'Прямое подключение',
          doh: 'DNS over HTTPS',
          proxy: 'Прокси',
          dns: 'Смена DNS',
          vpn: 'VPN'
        };
        bestEl.textContent = methodNames[data.bypass.bestMethod] || data.bypass.bestMethod;
      }

      // Рекомендации
      const recContainer = document.getElementById('smart-recommendations');
      if (recContainer && data.bypass.recommendations?.length > 0) {
        recContainer.innerHTML = data.bypass.recommendations.map(r =>
          `<div class="status-badge status-warning" style="display: inline-block; margin: 4px;">
            ⚠️ ${r.title}
          </div>`
        ).join('');
      } else if (recContainer) {
        recContainer.innerHTML = '<span class="status-badge status-success">✓ Нет рекомендаций</span>';
      }
    }

    async function testBypass() {
      log('Тестирование методов обхода...', 'info');
      const btn = event.target.closest('button');
      if (btn) {
        btn.disabled = true;
        btn.classList.add('loading');
      }

      try {
        const result = await api('/smart/test', { method: 'POST' });
        if (result.success) {
          displayBypassTestResult(result.result, result.best);
          log(`Тест завершен. Лучший метод: ${result.best}`, 'success');
        }
      } catch (error) {
        log(`Ошибка теста: ${error.message}`, 'error');
      } finally {
        if (btn) {
          btn.disabled = false;
          btn.classList.remove('loading');
        }
      }
    }

    function displayBypassTestResult(result, best) {
      const methods = {
        direct: result.direct,
        doh: result.doh,
        proxy: result.proxy,
        dns: result.dns
      };

      const methodNames = {
        direct: 'Прямое',
        doh: 'DoH',
        proxy: 'Прокси',
        dns: 'DNS'
      };

      // Обновление UI
      for (const [key, value] of Object.entries(methods)) {
        const el = document.getElementById(`method-${key}`);
        if (el) {
          el.textContent = value?.success ? '✓' : '✗';
          el.style.color = value?.success ? '#10b981' : '#ef4444';
        }
      }

      // Лучший метод
      const bestEl = document.getElementById('best-method');
      if (bestEl) {
        bestEl.textContent = methodNames[best] || best;
      }
    }

    async function applyBestBypass() {
      log('Применение лучшего метода...', 'info');
      const btn = event.target.closest('button');
      if (btn) {
        btn.disabled = true;
        btn.classList.add('loading');
      }

      try {
        const result = await api('/smart/apply', { method: 'POST' });
        if (result.success) {
          log(`Применено: ${result.result.method}`, 'success');
          // Обновление статуса через WebSocket
          if (ws && ws.readyState === WebSocket.OPEN) {
            ws.send(JSON.stringify({ type: 'request_status' }));
          }
        }
      } catch (error) {
        log(`Ошибка: ${error.message}`, 'error');
      } finally {
        if (btn) {
          btn.disabled = false;
          btn.classList.remove('loading');
        }
      }
    }

    // Initial load
    document.addEventListener('DOMContentLoaded', () => {
      checkMonitor();
      loadSystemInfo();
      loadProxyList();
      loadDNS();
      loadFingerprint();
      loadNotificationStatus();
      loadAutoRotationStatus();
      initWebSocket();
      log('Bypass Tools загружен', 'success');
    });
  </script>
</body>
</html>
