<!DOCTYPE html>
<html lang="<%= typeof lang !== 'undefined' ? lang : 'ru' %>">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= typeof t !== 'undefined' ? t('title') : 'Sazumi Cloud' %></title>
  <meta name="description" content="<%= typeof t !== 'undefined' ? t('description') : '' %>">
  <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Google+Sans:wght@400;500;700&display=swap">
  <link href="https://cdn.jsdelivr.net/npm/remixicon@3.5.0/fonts/remixicon.css" rel="stylesheet">
  <script src="https://cdn.tailwindcss.com"></script>
  <link rel="stylesheet" href="/css/style.css">
  <link rel="icon" href="data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 100 100%22><text y=%22.9em%22 font-size=%2290%22>🛡️</text></svg>">
  <style>
    .lang-switcher {
      position: fixed;
      top: 20px;
      right: 20px;
      z-index: 1000;
      display: flex;
      gap: 8px;
    }
    .lang-btn {
      padding: 8px 12px;
      border: 1px solid #757575;
      background: white;
      border-radius: 6px;
      cursor: pointer;
      font-size: 14px;
      transition: all 0.2s;
    }
    .lang-btn:hover {
      background: #f5f5f5;
    }
    .lang-btn.active {
      background: #757575;
      color: white;
    }
  </style>
</head>
<body>
  <!-- Language Switcher -->
  <div class="lang-switcher">
    <button class="lang-btn" data-lang="ru" title="Русский">🇷🇺 RU</button>
    <button class="lang-btn" data-lang="en" title="English">🇬🇧 EN</button>
    <button class="lang-btn" data-lang="zh" title="中文">🇨🇳 中文</button>
  </div>

  <!-- Disclaimer Modal -->
  <div id="disclaimer-modal" class="modal">
    <div class="modal-content">
      <div class="modal-header">
        <h2><i class="ri-alert-line"></i> <%= typeof t !== 'undefined' ? t('modalDisclaimer') : '' %></h2>
        <span class="modal-close">&times;</span>
      </div>
      <div class="modal-body">
        <div class="alert alert-warning">
          <i class="ri-error-warning-line"></i>
          <strong><%= typeof t !== 'undefined' ? t('modalWarning') : '' %></strong>
        </div>
        <p><%= typeof t !== 'undefined' ? t('modalAcknowledge') : '' %></p>
        <ul>
          <li><%= typeof t !== 'undefined' ? t('modalRisk') : '' %></li>
          <li><%= typeof t !== 'undefined' ? t('modalNoResponsibility') : '' %></li>
          <li><%= typeof t !== 'undefined' ? t('modalNotAbuse') : '' %></li>
          <li><%= typeof t !== 'undefined' ? t('modalEducational') : '' %></li>
        </ul>
        <p><%= typeof t !== 'undefined' ? t('disclaimerEducational') : '' %></p>
      </div>
      <div class="modal-footer">
        <button id="accept-disclaimer" class="btn"><%= typeof t !== 'undefined' ? t('modalAccept') : '' %></button>
      </div>
    </div>
  </div>

  <div class="container">
    <header>
      <h1>Sazumi Cloud</h1>
      <p><%= typeof t !== 'undefined' ? t('headerSubtitle') : '' %></p>
      <span class="version-label"><%= typeof t !== 'undefined' ? t('versionLabel') : '' %></span>
      <a href="/bypass" class="btn" style="margin-top: 16px; background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); color: white;">
        <i class="ri-global-line"></i> Bypass Tools - Обход блокировок
      </a>
    </header>

    <section id="intro">
      <div class="card">
        <div class="card-header">
          <h2><i class="ri-file-info-line"></i><%= typeof t !== 'undefined' ? t('aboutTitle') : '' %></h2>
        </div>
        <div class="card-body">
          <div class="alert alert-info" style="margin-bottom:1rem;">
            <i class="ri-information-line"></i>
            <strong><%= typeof t !== 'undefined' ? t('featureRecommended') : '' %></strong>
          </div>
          <p><%= typeof t !== 'undefined' ? t('aboutDescription') : '' %></p>
          <div class="features">
            <div class="feature">
              <i class="ri-shield-check-line"></i>
              <div>
                <h3><%= typeof t !== 'undefined' ? t('featureTokenBypass') : '' %></h3>
                <p><%= typeof t !== 'undefined' ? t('featureTokenBypassDesc') : '' %></p>
              </div>
            </div>
            <div class="feature">
              <i class="ri-vip-crown-line"></i>
              <div>
                <h3><%= typeof t !== 'undefined' ? t('featureProConversion') : '' %></h3>
                <p><%= typeof t !== 'undefined' ? t('featureProConversionDesc') : '' %></p>
              </div>
            </div>
            <div class="feature">
              <i class="ri-restart-line"></i>
              <div>
                <h3><%= typeof t !== 'undefined' ? t('featureMachineIdReset') : '' %></h3>
                <p><%= typeof t !== 'undefined' ? t('featureMachineIdResetDesc') : '' %></p>
              </div>
            </div>
            <div class="feature">
              <i class="ri-shield-flash-line"></i>
              <div>
                <h3><%= typeof t !== 'undefined' ? t('featureAutoUpdateBlock') : '' %></h3>
                <p><%= typeof t !== 'undefined' ? t('featureAutoUpdateBlockDesc') : '' %></p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <main>
      <div class="card">
        <div class="card-header">
          <h2><i class="ri-computer-line"></i><%= typeof t !== 'undefined' ? t('systemInfoTitle') : '' %></h2>
        </div>
        <div class="card-body">
          <div id="system-info">
            <div class="loading"><%= typeof t !== 'undefined' ? t('systemInfoLoading') : '' %></div>
          </div>
        </div>
      </div>

      <div class="card">
        <div class="card-header">
          <h2><i class="ri-apps-line"></i><%= typeof t !== 'undefined' ? t('cursorStatusTitle') : '' %></h2>
        </div>
        <div class="card-body">
          <div id="cursor-status">
            <div class="loading"><%= typeof t !== 'undefined' ? t('cursorStatusLoading') : '' %></div>
          </div>
        </div>
      </div>

      <div class="card">
        <div class="card-header">
          <h2><i class="ri-lock-unlock-line"></i><%= typeof t !== 'undefined' ? t('resetTitle') : '' %></h2>
        </div>
        <div class="card-body">
          <div class="alert alert-info">
            <i class="ri-information-line"></i>
            <strong><%= typeof t !== 'undefined' ? t('resetImportant') : '' %></strong>
          </div>
          <div class="action-grid">
            <button id="reset-btn" class="btn"><i class="ri-refresh-line"></i><%= typeof t !== 'undefined' ? t('resetBtn') : '' %></button>
            <button id="bypass-btn" class="btn btn-warning"><i class="ri-shield-flash-line"></i><%= typeof t !== 'undefined' ? t('bypassBtn') : '' %></button>
            <button id="disable-update-btn" class="btn btn-info"><i class="ri-lock-line"></i><%= typeof t !== 'undefined' ? t('disableUpdateBtn') : '' %></button>
            <button id="pro-convert-btn" class="btn btn-success"><i class="ri-vip-crown-line"></i><%= typeof t !== 'undefined' ? t('proConvertBtn') : '' %></button>
          </div>
          <div id="reset-result"></div>
        </div>
      </div>

      <div class="card">
        <div class="card-header">
          <h2><i class="ri-mail-line"></i><%= typeof t !== 'undefined' ? t('emailTitle') : '' %></h2>
        </div>
        <div class="card-body">
          <div class="alert alert-info">
            <i class="ri-information-line"></i>
            <strong><%= typeof t !== 'undefined' ? t('emailNote') : '' %></strong>
          </div>
          <div class="email-generator-container">
            <p><%= typeof t !== 'undefined' ? t('emailRemoved') : '' %></p>
            <p><%= typeof t !== 'undefined' ? t('emailExternal') : '' %></p>
          </div>
        </div>
      </div>
    </main>

    <section id="requirements">
      <div class="card">
        <div class="card-header">
          <h2><i class="ri-list-check"></i><%= typeof t !== 'undefined' ? t('requirementsTitle') : '' %></h2>
        </div>
        <div class="card-body">
          <ul class="req-list">
            <li><i class="ri-checkbox-circle-line"></i><%= typeof t !== 'undefined' ? t('reqAdmin') : '' %></li>
            <li><i class="ri-checkbox-circle-line"></i><%= typeof t !== 'undefined' ? t('reqClosed') : '' %></li>
            <li><i class="ri-checkbox-circle-line"></i><%= typeof t !== 'undefined' ? t('reqInternet') : '' %></li>
            <li><i class="ri-checkbox-circle-line"></i><%= typeof t !== 'undefined' ? t('reqCompatible') : '' %></li>
          </ul>
        </div>
      </div>
    </section>

    <section id="docs">
      <div class="card">
        <div class="card-header">
          <h2><i class="ri-question-line"></i><%= typeof t !== 'undefined' ? t('docsTitle') : '' %></h2>
        </div>
        <div class="card-body">
          <div class="accordion">
            <div class="accordion-item">
              <div class="accordion-header">
                <i class="ri-arrow-right-s-line"></i>
                <h3><%= typeof t !== 'undefined' ? t('docsHowItWorks') : '' %></h3>
              </div>
              <div class="accordion-content">
                <p><%= typeof t !== 'undefined' ? t('aboutDescription') : '' %></p>
              </div>
            </div>
            <div class="accordion-item">
              <div class="accordion-header">
                <i class="ri-arrow-right-s-line"></i>
                <h3><%= typeof t !== 'undefined' ? t('docsPrerequisites') : '' %></h3>
              </div>
              <div class="accordion-content">
                <ul>
                  <li><%= typeof t !== 'undefined' ? t('reqClosed') : '' %></li>
                  <li><%= typeof t !== 'undefined' ? t('reqAdmin') : '' %></li>
                  <li><%= typeof t !== 'undefined' ? t('featureRecommended') : '' %></li>
                </ul>
              </div>
            </div>
            <div class="accordion-item">
              <div class="accordion-header">
                <i class="ri-arrow-right-s-line"></i>
                <h3><%= typeof t !== 'undefined' ? t('docsTroubleshooting') : '' %></h3>
              </div>
              <div class="accordion-content">
                <ul>
                  <li><%= typeof t !== 'undefined' ? t('reqAdmin') : '' %></li>
                  <li><%= typeof t !== 'undefined' ? t('reqClosed') : '' %></li>
                </ul>
              </div>
            </div>
            <div class="accordion-item">
              <div class="accordion-header">
                <i class="ri-arrow-right-s-line"></i>
                <h3><%= typeof t !== 'undefined' ? t('docsTips') : '' %></h3>
              </div>
              <div class="accordion-content">
                <p><a href="https://mail.sazumi.com" target="_blank" style="color: #0000FF;">Sazumi Cloud - Email Disposable</a></p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <section id="installation">
      <div class="card">
        <div class="card-header">
          <h2><i class="ri-install-line"></i><%= typeof t !== 'undefined' ? t('installationTitle') : '' %></h2>
        </div>
        <div class="card-body">
          <div class="alert alert-warning">
            <i class="ri-alert-line"></i>
            <strong><%= typeof t !== 'undefined' ? t('installationWarning') : '' %></strong>
          </div>

          <div class="installation-steps">
            <div class="step">
              <div class="step-number">1</div>
              <div class="step-content">
                <h3><%= typeof t !== 'undefined' ? t('step1Title') : '' %></h3>
                <div class="code-block">git clone https://github.com/QuadDarv1ne/cursor-reset-tools.git
cd cursor-reset-tools</div>
              </div>
            </div>

            <div class="step">
              <div class="step-number">2</div>
              <div class="step-content">
                <h3><%= typeof t !== 'undefined' ? t('step2Title') : '' %></h3>
                <div class="code-block">npm install</div>
              </div>
            </div>

            <div class="step">
              <div class="step-number">3</div>
              <div class="step-content">
                <h3><%= typeof t !== 'undefined' ? t('step3Title') : '' %></h3>
                <div class="code-block">npm start</div>
                <p><%= typeof t !== 'undefined' ? t('serverStart') : '' %> <span class="highlight">http://localhost:3000</span></p>
              </div>
            </div>
          </div>

          <div class="accordion">
            <div class="accordion-item">
              <div class="accordion-header">
                <i class="ri-arrow-right-s-line"></i>
                <h3><%= typeof t !== 'undefined' ? t('adminTitle') : '' %></h3>
              </div>
              <div class="accordion-content">
                <p>Windows:</p>
                <div class="code-block">cd path\to\cursor-reset-tools
npm start</div>
                <p>macOS/Linux:</p>
                <div class="code-block">cd path/to/cursor-reset-tools
sudo npm start</div>
              </div>
            </div>
            <div class="accordion-item">
              <div class="accordion-header">
                <i class="ri-arrow-right-s-line"></i>
                <h3><%= typeof t !== 'undefined' ? t('devModeTitle') : '' %></h3>
              </div>
              <div class="accordion-content">
                <div class="code-block">npm run dev</div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <section id="changelog">
      <div class="card">
        <div class="card-header">
          <h2><i class="ri-history-line"></i><%= typeof t !== 'undefined' ? t('changelogTitle') : '' %></h2>
        </div>
        <div class="card-body">
          <div class="timeline">
            <div class="timeline-item">
              <div class="timeline-dot"></div>
              <div class="timeline-content">
                <div class="version-header">
                  <span class="version-tag">v2.0.0</span>
                  <span class="timeline-date"><%= typeof t !== 'undefined' ? t('monthJuly') : '' %> 2025</span>
                </div>
                <div class="timeline-card">
                  <ul class="version-changes">
                    <li><span class="change-type improved"><%= typeof t !== 'undefined' ? t('changeImproved') : '' %></span> Major improvements to reset machine ID for all platforms</li>
                    <li><span class="change-type improved"><%= typeof t !== 'undefined' ? t('changeImproved') : '' %></span> More robust bypass token limit patching for new Cursor versions</li>
                    <li><span class="change-type improved"><%= typeof t !== 'undefined' ? t('changeImproved') : '' %></span> Disable auto-update now blocks all update channels and URLs</li>
                    <li><span class="change-type improved"><%= typeof t !== 'undefined' ? t('changeImproved') : '' %></span> Pro Conversion + Custom UI now works with latest UI changes</li>
                    <li><span class="change-type enhanced"><%= typeof t !== 'undefined' ? t('changeEnhanced') : '' %></span> Cross-platform support and error handling</li>
                    <li><span class="change-type enhanced"><%= typeof t !== 'undefined' ? t('changeEnhanced') : '' %></span> UI/UX for system and Cursor status detection</li>
                    <li><span class="change-type enhanced"><%= typeof t !== 'undefined' ? t('changeEnhanced') : '' %></span> All features tested and optimized for Cursor 0.49.x</li>
                  </ul>
                </div>
              </div>
            </div>

            <div class="timeline-item">
              <div class="timeline-dot"></div>
              <div class="timeline-content">
                <div class="version-header">
                  <span class="version-tag">v1.9.0</span>
                  <span class="timeline-date"><%= typeof t !== 'undefined' ? t('monthJune') : '' %> 2025</span>
                </div>
                <div class="timeline-card">
                  <ul class="version-changes">
                    <li><span class="change-type improved"><%= typeof t !== 'undefined' ? t('changeImproved') : '' %></span> Complete machine ID reset to properly bypass device limits</li>
                    <li><span class="change-type added"><%= typeof t !== 'undefined' ? t('changeAdded') : '' %></span> Enhanced registry updates for Windows with both HKCU and HKLM keys</li>
                    <li><span class="change-type added"><%= typeof t !== 'undefined' ? t('changeAdded') : '' %></span> macOS keychain credential clearing for complete reset</li>
                    <li><span class="change-type added"><%= typeof t !== 'undefined' ? t('changeAdded') : '' %></span> Improved Linux support with additional identity file handling</li>
                    <li><span class="change-type enhanced"><%= typeof t !== 'undefined' ? t('changeEnhanced') : '' %></span> SQLite database modifications with trial-related entry deletion</li>
                    <li><span class="change-type improved"><%= typeof t !== 'undefined' ? t('changeImproved') : '' %></span> More robust getMachineId function patching with direct UUID injection</li>
                    <li><span class="change-type improved"><%= typeof t !== 'undefined' ? t('changeImproved') : '' %></span> Better error handling and file existence checks</li>
                  </ul>
                </div>
              </div>
            </div>

            <div class="timeline-item">
              <div class="timeline-dot"></div>
              <div class="timeline-content">
                <div class="version-header">
                  <span class="version-tag">v1.0.0</span>
                  <span class="timeline-date"><%= typeof t !== 'undefined' ? t('monthApril') : '' %> 2025</span>
                </div>
                <div class="timeline-card">
                  <ul class="version-changes">
                    <li><span class="change-type new"><%= typeof t !== 'undefined' ? t('changeNew') : '' %></span> Initial release of Sazumi Cloud</li>
                    <li><span class="change-type new"><%= typeof t !== 'undefined' ? t('changeNew') : '' %></span> Support for Windows, macOS and Linux</li>
                    <li><span class="change-type new"><%= typeof t !== 'undefined' ? t('changeNew') : '' %></span> Machine ID reset functionality</li>
                    <li><span class="change-type new"><%= typeof t !== 'undefined' ? t('changeNew') : '' %></span> System information display</li>
                  </ul>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <section id="actions">
      <div class="action-buttons">
        <a href="https://github.com/QuadDarv1ne/cursor-reset-tools" target="_blank" class="action-btn github-btn">
          <i class="ri-github-fill"></i>
          <span><%= typeof t !== 'undefined' ? t('github') : '' %></span>
        </a>
        <a href="https://sociabuzz.com/maestro7it/tribe" class="action-btn donate-btn">
          <i class="ri-hand-heart-line"></i>
          <span><%= typeof t !== 'undefined' ? t('donate') : '' %></span>
        </a>
      </div>
    </section>

    <footer>
      <p>© <span id="current-year"></span> <%= typeof t !== 'undefined' ? t('footer') : '' %></p>
      <p class="text-sm text-gray-400"><%= typeof t !== 'undefined' ? t('footerProduct') : '' %></p>
    </footer>
  </div>

  <script src="/js/main.js"></script>
  <script>
    document.getElementById('current-year').textContent = new Date().getFullYear();

    // i18n система для main.js
    window.i18n = {
      translations: <%= JSON.stringify(translations) %>,
      t: function(key, lang = '<%= lang %>') {
        const language = this.translations[lang] || this.translations.ru || {};
        return language[key] || this.translations.en[key] || key;
      }
    };

    // Language Switcher
    const currentLang = '<%= lang %>';
    document.querySelectorAll('.lang-btn').forEach(btn => {
      if (btn.dataset.lang === currentLang) {
        btn.classList.add('active');
      }
      btn.addEventListener('click', () => {
        const lang = btn.dataset.lang;
        localStorage.setItem('lang', lang);
        window.location.href = window.location.pathname + '?lang=' + lang;
      });
    });
  </script>
</body>
</html>
